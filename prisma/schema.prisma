// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

enum NodeType {
  GLOBAL
  REGION
  CITY
  INDUSTRY
  FUNCTIONAL
  AGENT
}

enum NodeStatus {
  DRAFT
  SUBMITTED
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ProjectStage {
  IDEA
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  GROWTH
  PUBLIC
  OTHER
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
}

enum TaskType {
  FUNDRAISING
  GROWTH
  RESOURCE
  LIQUIDITY
  RESEARCH
  EXECUTION
  OTHER
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  WAITING_REVIEW
  DONE
  CANCELLED
}

enum AssignmentRole {
  LEAD
  COLLABORATOR
}

enum EvidenceType {
  CONTRACT
  TRANSFER
  REPORT
  SCREENSHOT
  LINK
  ONCHAIN_TX
  OTHER
}

enum ReviewTargetType {
  NODE
  PROJECT
  TASK
  POB
  APPLICATION
}

enum ReviewDecision {
  APPROVE
  REJECT
  NEEDS_CHANGES
}

enum ReviewStatus {
  OPEN
  RESOLVED
}

enum ActorType {
  USER
  NODE
  AGENT
  SYSTEM
}

enum ConfirmationTargetType {
  POB
  TASK
  PROJECT
}

enum ConfirmationPartyType {
  USER
  NODE
}

enum ConfirmationDecision {
  CONFIRM
  REJECT
}

enum AttributionRole {
  LEAD
  COLLAB
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum AgentType {
  DEAL
  RESEARCH
  GROWTH
  EXECUTION
  LIQUIDITY
}

enum AgentStatus {
  ACTIVE
  DISABLED
}

enum AgentRunStatus {
  SUCCESS
  FAILED
  CANCELLED
}

enum SettlementCycleKind {
  WEEK
  MONTH
}

enum SettlementCycleStatus {
  DRAFT
  LOCKED
  FINALIZED
}

enum StakeAction {
  DEPOSIT
  WITHDRAW
  FREEZE
  UNFREEZE
  SLASH
}

enum PenaltyType {
  FREEZE
  SLASH
  DOWNGRADE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)

  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  nodes         Node[]         @relation("NodeOwner")
  reviews       Review[]
  confirmations Confirmation[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)

  // Applicant details
  applicantName String
  organization  String?
  role          String?
  nodeType      String?
  resources     String?
  lookingFor    String?
  linkedin      String?
  contact       String
  whyWcn        String?

  // Admin review
  notes String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

model Node {
  id          String     @id @default(cuid())
  type        NodeType
  status      NodeStatus @default(DRAFT)
  name        String
  description String?
  tags        String[]   @default([])

  region       String?
  city         String?
  jurisdiction String?

  level Int @default(1)

  ownerUserId String?
  owner       User?   @relation("NodeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects        Project[]
  tasksAsOwner    Task[]           @relation("TaskOwnerNode")
  assignments     TaskAssignment[]
  evidences       Evidence[]
  pobRecords      PoBRecord[]
  ownedAgents     Agent[]
  seats           NodeSeat[]
  stakeLedger     StakeLedger[]
  penalties       Penalty[]
  confirmations   Confirmation[]
  attributions    Attribution[]
  settlementLines SettlementLine[]

  @@index([type, status, createdAt])
  @@index([ownerUserId])
}

model Project {
  id       String        @id @default(cuid())
  status   ProjectStatus @default(DRAFT)
  name     String
  stage    ProjectStage  @default(OTHER)
  sector   String?
  website  String?
  pitchUrl String?

  fundraisingNeed String?
  contactName     String?
  contactEmail    String?
  contactTelegram String?

  description String?

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  tasks      Task[]
  pobRecords PoBRecord[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  evidence  Evidence[]

  @@index([status, createdAt])
  @@index([nodeId])
}

model Task {
  id          String     @id @default(cuid())
  type        TaskType
  status      TaskStatus @default(OPEN)
  title       String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  ownerNodeId String?
  ownerNode   Node?   @relation("TaskOwnerNode", fields: [ownerNodeId], references: [id], onDelete: SetNull)

  dueAt DateTime?

  assignments TaskAssignment[]
  evidences   Evidence[]
  pobRecords  PoBRecord[]
  agentRuns   AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, createdAt])
  @@index([projectId])
  @@index([ownerNodeId])
}

model TaskAssignment {
  id   String         @id @default(cuid())
  role AssignmentRole @default(COLLABORATOR)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([taskId, nodeId])
  @@index([nodeId])
}

model Evidence {
  id        String       @id @default(cuid())
  type      EvidenceType @default(OTHER)
  title     String?
  summary   String?
  url       String?
  onchainTx String?

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([taskId])
  @@index([projectId])
  @@index([nodeId])
}

model PoBRecord {
  id           String @id @default(cuid())
  businessType String

  baseValue    Float @default(0)
  weight       Float @default(1)
  qualityMult  Float @default(1)
  timeMult     Float @default(1)
  riskDiscount Float @default(1)
  score        Float @default(0)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  status ApplicationStatus @default(PENDING)
  notes  String?

  attributions  Attribution[]
  confirmations Confirmation[]
  disputes      Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([taskId])
  @@index([projectId])
  @@index([nodeId])
}

model Review {
  id         String           @id @default(cuid())
  targetType ReviewTargetType
  targetId   String
  decision   ReviewDecision
  notes      String?

  status    ReviewStatus @default(OPEN)
  actorType ActorType    @default(USER)
  actorId   String?
  version   Int          @default(1)
  metadata  Json?

  reviewerId String?
  reviewer   User?   @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([reviewerId])
}

model Confirmation {
  id         String                 @id @default(cuid())
  targetType ConfirmationTargetType
  targetId   String
  decision   ConfirmationDecision
  notes      String?

  partyType   ConfirmationPartyType
  partyUserId String?
  partyNodeId String?
  partyUser   User?                 @relation(fields: [partyUserId], references: [id], onDelete: SetNull)
  partyNode   Node?                 @relation(fields: [partyNodeId], references: [id], onDelete: SetNull)

  pobId String?
  pob   PoBRecord? @relation(fields: [pobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([partyType, createdAt])
  @@index([pobId])
}

model Attribution {
  id    String    @id @default(cuid())
  pobId String
  pob   PoBRecord @relation(fields: [pobId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  role         AttributionRole @default(COLLAB)
  shareBps     Int
  evidenceRefs String[]        @default([])

  createdAt DateTime @default(now())

  @@unique([pobId, nodeId])
  @@index([nodeId])
}

model Dispute {
  id         String           @id @default(cuid())
  pobId      String?
  pob        PoBRecord?       @relation(fields: [pobId], references: [id], onDelete: Cascade)
  targetType ReviewTargetType
  targetId   String
  reason     String
  status     DisputeStatus    @default(OPEN)
  resolution String?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([targetType, targetId, status, createdAt])
  @@index([pobId])
}

model Agent {
  id       String      @id @default(cuid())
  name     String
  type     AgentType
  status   AgentStatus @default(ACTIVE)
  version  Int         @default(1)
  endpoint String?

  ownerNodeId String
  ownerNode   Node   @relation(fields: [ownerNodeId], references: [id], onDelete: Cascade)

  permissions AgentPermission[]
  runs        AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerNodeId, type, status])
}

model AgentPermission {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scope      String
  canWrite   Boolean  @default(false)
  auditLevel Int      @default(1)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([agentId, scope])
}

model AgentRun {
  id         String         @id @default(cuid())
  agentId    String
  agent      Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  status     AgentRunStatus @default(SUCCESS)
  inputs     Json?
  outputs    Json?
  cost       Float?
  startedAt  DateTime       @default(now())
  finishedAt DateTime?

  @@index([agentId, startedAt])
  @@index([taskId])
}

model SettlementCycle {
  id            String                @id @default(cuid())
  kind          SettlementCycleKind
  status        SettlementCycleStatus @default(DRAFT)
  startAt       DateTime
  endAt         DateTime
  pool          Float                 @default(0)
  policyVersion Int                   @default(1)
  metadata      Json?

  lines SettlementLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, startAt, endAt])
  @@index([status, startAt])
}

model SettlementLine {
  id      String          @id @default(cuid())
  cycleId String
  cycle   SettlementCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  scoreTotal Float @default(0)
  allocation Float @default(0)
  pobCount   Int   @default(0)

  createdAt DateTime @default(now())

  @@unique([cycleId, nodeId])
  @@index([nodeId])
}

model NodeSeat {
  id        String   @id @default(cuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  level     Int      @default(1)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  @@index([nodeId, level])
}

model StakeLedger {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  action    StakeAction
  amount    Float       @default(0)
  notes     String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([nodeId, createdAt])
}

model Penalty {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  type      PenaltyType
  amount    Float?
  reason    String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([nodeId, createdAt])
}
