generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  FOUNDER
  FINANCE_ADMIN
  NODE_OWNER
  PROJECT_OWNER
  CAPITAL_NODE
  SERVICE_NODE
  REVIEWER
  AGENT_OWNER
  OBSERVER
}

enum AccountStatus {
  INVITED
  ACTIVE
  PENDING_2FA
  SUSPENDED
  LOCKED
  OFFBOARDED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

enum NodeType {
  GLOBAL
  REGION
  CITY
  INDUSTRY
  FUNCTIONAL
  AGENT
}

enum NodeStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEED_MORE_INFO
  APPROVED
  REJECTED
  CONTRACTING
  LIVE
  PROBATION
  SUSPENDED
  OFFBOARDED
  // legacy (kept for migration compat)
  ACTIVE
}

enum ProjectStage {
  IDEA
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  GROWTH
  PUBLIC
  OTHER
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  SCREENED
  CURATED
  IN_DEAL_ROOM
  ACTIVE
  ON_HOLD
  APPROVED
  REJECTED
  ARCHIVED
}

enum CapitalStatus {
  PROSPECT
  QUALIFIED
  ACTIVE
  WARM
  IN_DD
  CLOSED
  PASSED
  DORMANT
}

enum DealStage {
  SOURCED
  MATCHED
  INTRO_SENT
  MEETING_DONE
  DD
  TERM_SHEET
  SIGNED
  FUNDED
  PASSED
  PAUSED
}

enum TaskType {
  FUNDRAISING
  GROWTH
  RESOURCE
  LIQUIDITY
  RESEARCH
  EXECUTION
  OTHER
}

enum TaskStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REWORK
  BLOCKED
  CANCELLED
  CLOSED
  // legacy (kept for migration compat)
  OPEN
  WAITING_REVIEW
  DONE
}

enum AssignmentRole {
  LEAD
  COLLABORATOR
}

enum EvidenceType {
  CONTRACT
  TRANSFER
  REPORT
  SCREENSHOT
  LINK
  ONCHAIN_TX
  OTHER
}

enum EvidenceReviewStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISPUTED
}

enum PoBEventStatus {
  CREATED
  PENDING_REVIEW
  EFFECTIVE
  REJECTED
  FROZEN
}

enum ReviewTargetType {
  NODE
  PROJECT
  TASK
  POB
  APPLICATION
  DEAL
  CAPITAL
  EVIDENCE
}

enum ReviewDecision {
  APPROVE
  REJECT
  NEEDS_CHANGES
}

enum ReviewStatus {
  OPEN
  RESOLVED
}

enum ActorType {
  USER
  NODE
  AGENT
  SYSTEM
}

enum ConfirmationTargetType {
  POB
  TASK
  PROJECT
  DEAL
}

enum ConfirmationPartyType {
  USER
  NODE
}

enum ConfirmationDecision {
  CONFIRM
  REJECT
}

enum AttributionRole {
  LEAD
  COLLAB
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum AgentType {
  DEAL
  RESEARCH
  GROWTH
  EXECUTION
  LIQUIDITY
}

enum AgentStatus {
  ACTIVE
  DISABLED
  FROZEN
}

enum AgentRunStatus {
  SUCCESS
  FAILED
  CANCELLED
}

enum AgentOverrideLevel {
  L1_PAUSE_TASK
  L2_PAUSE_INSTANCE
  L3_PAUSE_CLASS
}

enum SettlementCycleKind {
  WEEK
  MONTH
}

enum SettlementCycleStatus {
  DRAFT
  RECONCILED
  LOCKED
  EXPORTED
  REOPENED
  FINALIZED
}

enum StakeAction {
  DEPOSIT
  WITHDRAW
  FREEZE
  UNFREEZE
  SLASH
}

enum PenaltyType {
  FREEZE
  SLASH
  DOWNGRADE
}

enum ConfidentialityLevel {
  PUBLIC
  CERTIFIED_NODE
  DEAL_ROOM
  RESTRICTED
}

enum NotificationType {
  TASK_ASSIGNED
  EVIDENCE_NEEDED
  REVIEW_REJECTED
  DISPUTE_OPENED
  SETTLEMENT_CLOSING
  SLA_WARNING
  INVITE_SENT
  NODE_STATUS_CHANGE
  DEAL_STAGE_CHANGE
  GENERAL
}

// ─── AUTH & IDENTITY ────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role          @default(USER)
  accountStatus AccountStatus @default(ACTIVE)

  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  ndaAcceptedAt    DateTime?
  lockedAt         DateTime?
  lockReason       String?
  failedLoginCount Int      @default(0)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  lastLoginDevice  String?

  accounts             Account[]
  sessions             Session[]
  applications         Application[]
  nodes                Node[]              @relation("NodeOwner")
  reviews              Review[]
  confirmations        Confirmation[]
  auditLogs            AuditLog[]
  workspaceMemberships WorkspaceMembership[]
  invitesCreated       Invite[]            @relation("InviteCreator")
  notifications        Notification[]
  filesUploaded        File[]              @relation("FileUploader")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountStatus])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  deviceInfo   String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── WORKSPACE ──────────────────────────────────────────────────────────────

model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  memberships WorkspaceMembership[]
  invites     Invite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMembership {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role
  territory   String?
  region      String?

  createdAt DateTime @default(now())

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique @default(cuid())
  role        Role
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  activatedAt DateTime?
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ─── AUDIT ──────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  deviceInfo  String?
  ipAddress   String?
  workspaceId String?

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([workspaceId, createdAt])
}

// ─── APPLICATION / INTAKE ───────────────────────────────────────────────────

model Application {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)

  applicantName String
  organization  String?
  role          String?
  nodeType      String?
  resources     String?
  lookingFor    String?
  linkedin      String?
  contact       String
  whyWcn        String?
  notes         String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

// ─── NODE ───────────────────────────────────────────────────────────────────

model Node {
  id          String     @id @default(cuid())
  type        NodeType
  status      NodeStatus @default(DRAFT)
  name        String
  description String?
  tags        String[]   @default([])

  region       String?
  city         String?
  jurisdiction String?
  level        Int     @default(1)

  entityName       String?
  entityType       String?
  contactName      String?
  contactEmail     String?
  resourcesOffered String?
  pastCases        String?
  recommendation   String?
  allowedServices  String[] @default([])
  riskLevel        String?
  billingStatus    String?
  depositStatus    String?
  seatFeeStatus    String?

  probationStartAt DateTime?
  probationEndAt   DateTime?
  onboardingScore  Int?
  contractSentAt   DateTime?
  goLiveAt         DateTime?
  offboardedAt     DateTime?

  ownerUserId String?
  owner       User?   @relation("NodeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects           Project[]
  tasksAsOwner       Task[]             @relation("TaskOwnerNode")
  assignments        TaskAssignment[]
  evidences          Evidence[]
  pobRecords         PoBRecord[]
  ownedAgents        Agent[]
  seats              NodeSeat[]
  stakeLedger        StakeLedger[]
  penalties          Penalty[]
  confirmations      Confirmation[]
  attributions       Attribution[]
  settlementLines    SettlementLine[]
  capitalProfiles    CapitalProfile[]
  dealsAsLead        Deal[]             @relation("DealLeadNode")
  dealParticipations DealParticipant[]

  @@index([type, status, createdAt])
  @@index([ownerUserId])
}

// ─── PROJECT ────────────────────────────────────────────────────────────────

model Project {
  id       String        @id @default(cuid())
  status   ProjectStatus @default(DRAFT)
  name     String
  stage    ProjectStage  @default(OTHER)
  sector   String?
  website  String?
  pitchUrl String?

  fundraisingNeed String?
  contactName     String?
  contactEmail    String?
  contactTelegram String?
  description     String?

  confidentialityLevel ConfidentialityLevel @default(PUBLIC)
  riskTags             String[]             @default([])
  internalScore        Float?
  internalNotes        String?

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  tasks      Task[]
  pobRecords PoBRecord[]
  evidence   Evidence[]
  deals      Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([nodeId])
}

// ─── CAPITAL POOL ───────────────────────────────────────────────────────────

model CapitalProfile {
  id                String        @id @default(cuid())
  status            CapitalStatus @default(PROSPECT)
  name              String
  entity            String?
  investmentFocus   String[]      @default([])
  ticketMin         Float?
  ticketMax         Float?
  jurisdictionLimit String[]      @default([])
  structurePref     String[]      @default([])
  blacklist         String[]      @default([])
  restrictions      String?
  responseSpeed     Int?
  activityScore     Float?
  contactName       String?
  contactEmail      String?
  notes             String?

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([nodeId])
}

// ─── DEAL ROOM ──────────────────────────────────────────────────────────────

model Deal {
  id              String    @id @default(cuid())
  stage           DealStage @default(SOURCED)
  title           String
  description     String?
  riskTags        String[]  @default([])
  nextAction      String?
  nextActionDueAt DateTime?
  closedAt        DateTime?

  confidentialityLevel ConfidentialityLevel @default(DEAL_ROOM)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  capitalId String?
  capital   CapitalProfile? @relation(fields: [capitalId], references: [id], onDelete: SetNull)

  leadNodeId String
  leadNode   Node   @relation("DealLeadNode", fields: [leadNodeId], references: [id], onDelete: Cascade)

  participants DealParticipant[]
  milestones   DealMilestone[]
  notes        DealNote[]
  tasks        Task[]
  evidence     Evidence[]
  pobRecords   PoBRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([projectId])
  @@index([capitalId])
  @@index([leadNodeId])
}

model DealParticipant {
  id     String  @id @default(cuid())
  dealId String
  deal   Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  userId String?
  role   String

  joinedAt DateTime @default(now())

  @@unique([dealId, nodeId])
  @@index([dealId])
}

model DealMilestone {
  id     String    @id @default(cuid())
  dealId String
  deal   Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title  String
  dueAt  DateTime?
  doneAt DateTime?

  createdAt DateTime @default(now())

  @@index([dealId])
}

model DealNote {
  id       String @id @default(cuid())
  dealId   String
  deal     Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId String
  content  String

  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
}

// ─── TASK ───────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  type        TaskType
  status      TaskStatus @default(DRAFT)
  title       String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  ownerNodeId String?
  ownerNode   Node?   @relation("TaskOwnerNode", fields: [ownerNodeId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  assigneeUserId   String?
  evidenceRequired String[] @default([])
  acceptanceOwner  String?

  dueAt DateTime?

  assignments TaskAssignment[]
  evidences   Evidence[]
  pobRecords  PoBRecord[]
  agentRuns   AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, createdAt])
  @@index([projectId])
  @@index([ownerNodeId])
  @@index([dealId])
}

model TaskAssignment {
  id   String         @id @default(cuid())
  role AssignmentRole @default(COLLABORATOR)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([taskId, nodeId])
  @@index([nodeId])
}

// ─── EVIDENCE ───────────────────────────────────────────────────────────────

model Evidence {
  id        String       @id @default(cuid())
  type      EvidenceType @default(OTHER)
  title     String?
  summary   String?
  url       String?
  onchainTx String?

  fileId         String?
  hash           String?
  version        Int                  @default(1)
  reviewStatus   EvidenceReviewStatus @default(DRAFT)
  reviewedAt     DateTime?
  reviewerId     String?
  slaDeadlineAt  DateTime?

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([reviewStatus, slaDeadlineAt])
  @@index([taskId])
  @@index([projectId])
  @@index([nodeId])
  @@index([dealId])
}

// ─── POB ────────────────────────────────────────────────────────────────────

model PoBRecord {
  id           String @id @default(cuid())
  businessType String

  baseValue    Float @default(0)
  weight       Float @default(1)
  qualityMult  Float @default(1)
  timeMult     Float @default(1)
  riskDiscount Float @default(1)
  score        Float @default(0)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  // Legacy status kept for migration; new code uses pobEventStatus
  status ApplicationStatus @default(PENDING)

  pobEventStatus     PoBEventStatus @default(CREATED)
  leadNodeId         String?
  supportingNodeIds  String[]       @default([])
  beneficiaryEntity  String?
  resultDate         DateTime?
  loopType           String?
  slaDeadlineAt      DateTime?
  frozenAt           DateTime?
  frozenReason       String?

  notes String?

  attributions  Attribution[]
  confirmations Confirmation[]
  disputes      Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([pobEventStatus, createdAt])
  @@index([taskId])
  @@index([projectId])
  @@index([nodeId])
  @@index([dealId])
}

// ─── REVIEW / CONFIRMATION / ATTRIBUTION ────────────────────────────────────

model Review {
  id         String           @id @default(cuid())
  targetType ReviewTargetType
  targetId   String
  decision   ReviewDecision
  notes      String?

  status    ReviewStatus @default(OPEN)
  actorType ActorType    @default(USER)
  actorId   String?
  version   Int          @default(1)
  metadata  Json?

  reviewerId String?
  reviewer   User?   @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([reviewerId])
}

model Confirmation {
  id         String                 @id @default(cuid())
  targetType ConfirmationTargetType
  targetId   String
  decision   ConfirmationDecision
  notes      String?

  partyType   ConfirmationPartyType
  partyUserId String?
  partyNodeId String?
  partyUser   User?                 @relation(fields: [partyUserId], references: [id], onDelete: SetNull)
  partyNode   Node?                 @relation(fields: [partyNodeId], references: [id], onDelete: SetNull)

  pobId String?
  pob   PoBRecord? @relation(fields: [pobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([partyType, createdAt])
  @@index([pobId])
}

model Attribution {
  id    String    @id @default(cuid())
  pobId String
  pob   PoBRecord @relation(fields: [pobId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  role         AttributionRole @default(COLLAB)
  shareBps     Int
  evidenceRefs String[]        @default([])

  createdAt DateTime @default(now())

  @@unique([pobId, nodeId])
  @@index([nodeId])
}

// ─── DISPUTE ────────────────────────────────────────────────────────────────

model Dispute {
  id         String           @id @default(cuid())
  pobId      String?
  pob        PoBRecord?       @relation(fields: [pobId], references: [id], onDelete: Cascade)
  targetType ReviewTargetType
  targetId   String
  reason     String
  status     DisputeStatus    @default(OPEN)
  resolution String?

  windowEndsAt DateTime?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([targetType, targetId, status, createdAt])
  @@index([pobId])
}

// ─── AGENT ──────────────────────────────────────────────────────────────────

model Agent {
  id       String      @id @default(cuid())
  name     String
  type     AgentType
  status   AgentStatus @default(ACTIVE)
  version  Int         @default(1)
  endpoint String?

  freezeLevel AgentOverrideLevel?

  ownerNodeId String
  ownerNode   Node   @relation(fields: [ownerNodeId], references: [id], onDelete: Cascade)

  permissions AgentPermission[]
  runs        AgentRun[]
  logs        AgentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerNodeId, type, status])
}

model AgentPermission {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scope      String
  canWrite   Boolean  @default(false)
  auditLevel Int      @default(1)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([agentId, scope])
}

model AgentRun {
  id         String         @id @default(cuid())
  agentId    String
  agent      Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  status     AgentRunStatus @default(SUCCESS)
  inputs     Json?
  outputs    Json?
  cost       Float?
  startedAt  DateTime       @default(now())
  finishedAt DateTime?

  @@index([agentId, startedAt])
  @@index([taskId])
}

model AgentLog {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ownerNodeId     String
  taskId          String?
  caseId          String?
  modelVersion    String?
  actionType      String
  inputReference  String?
  outputReference String?
  humanApprovalId String?
  exceptionFlag   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([taskId])
}

// ─── SETTLEMENT ─────────────────────────────────────────────────────────────

model SettlementCycle {
  id            String                @id @default(cuid())
  kind          SettlementCycleKind
  status        SettlementCycleStatus @default(DRAFT)
  startAt       DateTime
  endAt         DateTime
  pool          Float                 @default(0)
  policyVersion Int                   @default(1)
  metadata      Json?

  reconciledAt DateTime?
  exportedAt   DateTime?
  reopenedAt   DateTime?
  reopenReason String?
  lockedById   String?
  exportedById String?

  lines SettlementLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, startAt, endAt])
  @@index([status, startAt])
}

model SettlementLine {
  id      String          @id @default(cuid())
  cycleId String
  cycle   SettlementCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  scoreTotal Float @default(0)
  allocation Float @default(0)
  pobCount   Int   @default(0)

  createdAt DateTime @default(now())

  @@unique([cycleId, nodeId])
  @@index([nodeId])
}

// ─── NODE STAKING ───────────────────────────────────────────────────────────

model NodeSeat {
  id        String   @id @default(cuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  level     Int      @default(1)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  @@index([nodeId, level])
}

model StakeLedger {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  action    StakeAction
  amount    Float       @default(0)
  notes     String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([nodeId, createdAt])
}

model Penalty {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  type      PenaltyType
  amount    Float?
  reason    String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([nodeId, createdAt])
}

// ─── FILE LAYER ─────────────────────────────────────────────────────────────

model File {
  id              String               @id @default(cuid())
  filename        String
  mimeType        String?
  sizeBytes       Int?
  storagePath     String?
  hash            String?
  version         Int                  @default(1)
  confidentiality ConfidentialityLevel @default(PUBLIC)

  uploaderUserId String
  uploader       User   @relation("FileUploader", fields: [uploaderUserId], references: [id], onDelete: Cascade)

  entityType   String
  entityId     String
  parentFileId String?

  accessLogs FileAccessLog[]

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([uploaderUserId])
  @@index([parentFileId])
}

model FileAccessLog {
  id     String @id @default(cuid())
  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId String
  action String

  createdAt DateTime @default(now())

  @@index([fileId, createdAt])
  @@index([userId, createdAt])
}

// ─── NOTIFICATION ───────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType @default(GENERAL)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  body       String?
  entityType String?
  entityId   String?
  readAt     DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt, createdAt])
}

// ─── RISK ───────────────────────────────────────────────────────────────────

model RiskFlag {
  id         String    @id @default(cuid())
  entityType String
  entityId   String
  severity   String
  reason     String
  raisedById String?
  resolvedAt DateTime?
  resolution String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([severity, createdAt])
  @@index([resolvedAt])
}
