generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  FOUNDER
  FINANCE_ADMIN
  NODE_OWNER
  PROJECT_OWNER
  CAPITAL_NODE
  SERVICE_NODE
  REVIEWER
  RISK_DESK
  AGENT_OWNER
  OBSERVER
  SYSTEM
}

enum AccountStatus {
  INVITED
  ACTIVE
  PENDING_2FA
  SUSPENDED
  LOCKED
  OFFBOARDED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

enum NodeType {
  GLOBAL
  REGION
  CITY
  INDUSTRY
  FUNCTIONAL
  AGENT
}

enum NodeStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEED_MORE_INFO
  APPROVED
  REJECTED
  CONTRACTING
  LIVE
  PROBATION
  SUSPENDED
  OFFBOARDED
  ACTIVE // legacy
}

enum ProjectStage {
  IDEA
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  GROWTH
  PUBLIC
  OTHER
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  SCREENED
  CURATED
  IN_DEAL_ROOM
  ACTIVE
  ON_HOLD
  APPROVED
  REJECTED
  ARCHIVED
}

enum CapitalStatus {
  PROSPECT
  QUALIFIED
  ACTIVE
  WARM
  IN_DD
  CLOSED
  PASSED
  DORMANT
}

enum DealStage {
  SOURCED
  MATCHED
  INTRO_SENT
  MEETING_DONE
  DD
  TERM_SHEET
  SIGNED
  FUNDED
  PASSED
  PAUSED
}

enum TaskType {
  FUNDRAISING
  GROWTH
  RESOURCE
  LIQUIDITY
  RESEARCH
  EXECUTION
  OTHER
}

enum TaskStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REWORK
  BLOCKED
  CANCELLED
  CLOSED
  OPEN            // legacy
  WAITING_REVIEW  // legacy
  DONE            // legacy
}

enum AssignmentRole {
  LEAD
  COLLABORATOR
}

enum EvidenceType {
  CONTRACT
  TRANSFER
  REPORT
  SCREENSHOT
  LINK
  ONCHAIN_TX
  OTHER
}

enum EvidenceReviewStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISPUTED
}

enum PoBEventStatus {
  CREATED
  PENDING_REVIEW
  EFFECTIVE
  REJECTED
  FROZEN
}

enum ReviewTargetType {
  NODE
  PROJECT
  TASK
  POB
  APPLICATION
  DEAL
  CAPITAL
  EVIDENCE
}

enum ReviewDecision {
  APPROVE
  REJECT
  NEEDS_CHANGES
}

enum ReviewStatus {
  OPEN
  RESOLVED
}

enum ActorType {
  USER
  NODE
  AGENT
  SYSTEM
}

enum ConfirmationTargetType {
  POB
  TASK
  PROJECT
  DEAL
}

enum ConfirmationPartyType {
  USER
  NODE
}

enum ConfirmationDecision {
  CONFIRM
  REJECT
}

enum AttributionRole {
  LEAD
  COLLAB
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
  ESCALATED
  REJECTED // legacy
}

enum AgentType {
  DEAL
  RESEARCH
  GROWTH
  EXECUTION
  LIQUIDITY
}

enum AgentStatus {
  ACTIVE
  DISABLED
  SUSPENDED
  FROZEN
}

enum AgentRunStatus {
  SUCCESS
  FAILED
  CANCELLED
}

enum AgentOverrideLevel {
  L1_PAUSE_TASK
  L2_PAUSE_INSTANCE
  L3_PAUSE_CLASS
}

enum SettlementCycleKind {
  WEEK
  MONTH
}

enum SettlementCycleStatus {
  DRAFT
  RECONCILED
  LOCK_PENDING_APPROVAL
  LOCKED
  EXPORTED
  REOPEN_PENDING_APPROVAL
  REOPENED
  FINALIZED
}

enum StakeAction {
  DEPOSIT
  WITHDRAW
  FREEZE
  UNFREEZE
  SLASH
}

enum PenaltyType {
  FREEZE
  SLASH
  DOWNGRADE
}

enum ConfidentialityLevel {
  PUBLIC
  CERTIFIED_NODE
  DEAL_ROOM
  RESTRICTED
}

enum NotificationType {
  TASK_ASSIGNED
  EVIDENCE_SUBMITTED
  EVIDENCE_NEEDED
  REVIEW_REJECTED
  DISPUTE_OPENED
  SETTLEMENT_CLOSING
  SLA_WARNING
  APPROVAL_PENDING
  FREEZE_APPLIED
  INVITE_SENT
  NODE_STATUS_CHANGE
  DEAL_STAGE_CHANGE
  GENERAL
}

// ─── v2.0 NEW ENUMS ────────────────────────────────────────────────────────

enum GrantType {
  VIEW
  DOWNLOAD
  COMMENT
  REVIEW
  MANAGE
  EXPORT
}

enum GrantScope {
  FULL
  MATERIALS_ONLY
  DEAL_ROOM_ONLY
  REVIEW_ONLY
  SETTLEMENT_PREVIEW_ONLY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ApprovalActionType {
  LOCK
  REOPEN
  FREEZE
  UNFREEZE
  OVERRIDE
}

enum FreezeLevel {
  SOFT
  HARD
}

enum ScanStatus {
  PENDING
  PASSED
  FAILED
}

enum PreviewStatus {
  PENDING
  READY
  FAILED
}

enum TermsDocumentType {
  NDA
  TERMS
  PRIVACY
  CODE_OF_CONDUCT
}

// ─── AUTH & IDENTITY ────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role          @default(USER)
  accountStatus AccountStatus @default(ACTIVE)

  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  ndaAcceptedAt    DateTime?
  lockedAt         DateTime?
  lockReason       String?
  failedLoginCount Int      @default(0)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  lastLoginDevice  String?

  activeWorkspaceId String?
  activeRole        Role?

  accounts             Account[]
  sessions             Session[]
  applications         Application[]
  nodes                Node[]              @relation("NodeOwner")
  reviews              Review[]
  confirmations        Confirmation[]
  auditLogs            AuditLog[]
  workspaceMemberships WorkspaceMembership[]
  invitesCreated       Invite[]            @relation("InviteCreator")
  notifications        Notification[]
  filesUploaded        File[]              @relation("FileUploader")
  termsAcceptances     TermsAcceptance[]
  roleAssignmentsGranted RoleAssignment[]  @relation("RoleGrantedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountStatus])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  deviceInfo   String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── WORKSPACE ──────────────────────────────────────────────────────────────

model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  status      String? // ACTIVE / SUSPENDED / ARCHIVED

  memberships WorkspaceMembership[]
  invites     Invite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMembership {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  territory   String?
  region      String?
  isPrimary   Boolean @default(false)
  status      String? // ACTIVE / SUSPENDED / OFFBOARDED

  roleAssignments RoleAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model RoleAssignment {
  id                    String   @id @default(cuid())
  workspaceMembershipId String
  membership            WorkspaceMembership @relation(fields: [workspaceMembershipId], references: [id], onDelete: Cascade)
  role                  Role
  grantedById           String?
  grantedBy             User?    @relation("RoleGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  grantedAt             DateTime @default(now())
  revokedAt             DateTime?

  @@index([workspaceMembershipId, role])
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  tokenHash   String    @unique
  role        Role
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  activatedAt DateTime?
  revokedAt   DateTime?
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([tokenHash])
}

// ─── TERMS / NDA ────────────────────────────────────────────────────────────

model TermsAcceptance {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId   String?
  documentType  TermsDocumentType
  documentVer   String
  acceptedAt    DateTime          @default(now())
  ipAddress     String?
  deviceInfo    String?

  @@index([userId, documentType, documentVer])
}

// ─── ACCESS GRANT ───────────────────────────────────────────────────────────

model AccessGrant {
  id              String      @id @default(cuid())
  workspaceId     String
  entityType      String
  entityId        String
  grantedToType   ActorType
  grantedToId     String
  grantType       GrantType
  scope           GrantScope  @default(FULL)
  expiresAt       DateTime?
  grantedById     String?
  createdAt       DateTime    @default(now())

  @@index([workspaceId, entityType, entityId])
  @@index([grantedToType, grantedToId])
}

// ─── APPROVAL (DUAL CONTROL) ────────────────────────────────────────────────

model ApprovalAction {
  id             String             @id @default(cuid())
  workspaceId    String
  entityType     String
  entityId       String
  actionType     ApprovalActionType
  requestedById  String
  approvedById   String?
  rejectedById   String?
  status         ApprovalStatus     @default(PENDING)
  reason         String?
  createdAt      DateTime           @default(now())
  decidedAt      DateTime?
  expiresAt      DateTime?

  @@index([workspaceId, entityType, entityId, status])
  @@index([status, createdAt])
}

// ─── ENTITY FREEZE ──────────────────────────────────────────────────────────

model EntityFreeze {
  id            String      @id @default(cuid())
  workspaceId   String
  entityType    String
  entityId      String
  freezeLevel   FreezeLevel
  reason        String
  frozenById    String
  frozenAt      DateTime    @default(now())
  expiresAt     DateTime?
  liftedAt      DateTime?
  liftedById    String?

  @@index([workspaceId, entityType, entityId])
  @@index([liftedAt])
}

// ─── SEARCH INDEX ───────────────────────────────────────────────────────────

model SearchDocument {
  id            String   @id @default(cuid())
  workspaceId   String
  entityType    String
  entityId      String
  title         String
  subtitle      String?
  body          String?
  tags          String[] @default([])
  updatedAt     DateTime @updatedAt

  @@unique([workspaceId, entityType, entityId])
  @@index([workspaceId, entityType])
}

// ─── AUDIT ──────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  deviceInfo  String?
  ipAddress   String?
  workspaceId String?
  requestId   String?
  actorId     String?
  before      Json?
  after       Json?

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([workspaceId, createdAt])
  @@index([requestId])
}

// ─── APPLICATION / INTAKE ───────────────────────────────────────────────────

model Application {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)

  applicantName String
  organization  String?
  role          String?
  nodeType      String?
  resources     String?
  lookingFor    String?
  linkedin      String?
  contact       String
  whyWcn        String?
  notes         String?
  workspaceId   String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@index([workspaceId])
}

// ─── NODE ───────────────────────────────────────────────────────────────────

model Node {
  id          String     @id @default(cuid())
  type        NodeType
  status      NodeStatus @default(DRAFT)
  name        String
  description String?
  tags        String[]   @default([])

  workspaceId  String?
  region       String?
  city         String?
  jurisdiction String?
  level        Int     @default(1)

  entityName       String?
  entityType       String?
  contactName      String?
  contactEmail     String?
  resourcesOffered String?
  pastCases        String?
  recommendation   String?
  allowedServices  String[] @default([])
  riskLevel        String?
  billingStatus    String?
  depositStatus    String?
  seatFeeStatus    String?

  probationStartAt DateTime?
  probationEndAt   DateTime?
  onboardingScore  Int?
  contractSentAt   DateTime?
  goLiveAt         DateTime?
  offboardedAt     DateTime?
  version          Int       @default(1)

  ownerUserId String?
  owner       User?   @relation("NodeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects           Project[]
  tasksAsOwner       Task[]             @relation("TaskOwnerNode")
  assignments        TaskAssignment[]
  evidences          Evidence[]
  pobRecords         PoBRecord[]
  ownedAgents        Agent[]
  seats              NodeSeat[]
  stakeLedger        StakeLedger[]
  penalties          Penalty[]
  confirmations      Confirmation[]
  attributions       Attribution[]
  settlementLines    SettlementLine[]
  capitalProfiles    CapitalProfile[]
  dealsAsLead        Deal[]             @relation("DealLeadNode")
  dealParticipations DealParticipant[]

  @@index([type, status, createdAt])
  @@index([ownerUserId])
  @@index([workspaceId])
}

// ─── PROJECT ────────────────────────────────────────────────────────────────

model Project {
  id       String        @id @default(cuid())
  status   ProjectStatus @default(DRAFT)
  name     String
  stage    ProjectStage  @default(OTHER)
  sector   String?
  website  String?
  pitchUrl String?

  workspaceId     String?
  fundraisingNeed String?
  contactName     String?
  contactEmail    String?
  contactTelegram String?
  description     String?

  confidentialityLevel ConfidentialityLevel @default(PUBLIC)
  riskTags             String[]             @default([])
  internalScore        Float?
  internalNotes        String?
  version              Int                  @default(1)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  tasks      Task[]
  pobRecords PoBRecord[]
  evidence   Evidence[]
  deals      Deal[]
  matches    Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([nodeId])
  @@index([workspaceId])
}

// ─── CAPITAL POOL ───────────────────────────────────────────────────────────

model CapitalProfile {
  id                String        @id @default(cuid())
  workspaceId       String?
  status            CapitalStatus @default(PROSPECT)
  name              String
  entity            String?
  investmentFocus   String[]      @default([])
  ticketMin         Float?
  ticketMax         Float?
  jurisdictionLimit String[]      @default([])
  structurePref     String[]      @default([])
  blacklist         String[]      @default([])
  restrictions      String?
  responseSpeed     Int?
  activityScore     Float?
  contactName       String?
  contactEmail      String?
  notes             String?
  version           Int           @default(1)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  deals   Deal[]
  matches Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([nodeId])
  @@index([workspaceId])
}

// ─── DEAL ROOM ──────────────────────────────────────────────────────────────

model Deal {
  id              String    @id @default(cuid())
  workspaceId     String?
  stage           DealStage @default(SOURCED)
  title           String
  description     String?
  riskTags        String[]  @default([])
  nextAction      String?
  nextActionDueAt DateTime?
  closedAt        DateTime?
  version         Int       @default(1)

  confidentialityLevel ConfidentialityLevel @default(DEAL_ROOM)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  capitalId String?
  capital   CapitalProfile? @relation(fields: [capitalId], references: [id], onDelete: SetNull)

  leadNodeId String
  leadNode   Node   @relation("DealLeadNode", fields: [leadNodeId], references: [id], onDelete: Cascade)

  participants DealParticipant[]
  milestones   DealMilestone[]
  notes        DealNote[]
  tasks        Task[]
  evidence     Evidence[]
  pobRecords   PoBRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([projectId])
  @@index([capitalId])
  @@index([leadNodeId])
  @@index([workspaceId])
}

model DealParticipant {
  id          String    @id @default(cuid())
  workspaceId String?
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actorType   ActorType @default(NODE)
  actorId     String?
  nodeId      String?
  node        Node?     @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  userId      String?
  role        String

  joinedAt DateTime @default(now())

  @@unique([dealId, nodeId])
  @@index([dealId])
  @@index([workspaceId, actorType, actorId])
}

model DealMilestone {
  id          String    @id @default(cuid())
  workspaceId String?
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String
  dueAt       DateTime?
  doneAt      DateTime?

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([workspaceId])
}

model DealNote {
  id          String @id @default(cuid())
  workspaceId String?
  dealId      String
  deal        Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId    String
  content     String

  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
  @@index([workspaceId])
}

// ─── TASK ───────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  workspaceId String?
  type        TaskType
  status      TaskStatus @default(DRAFT)
  title       String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  ownerNodeId String?
  ownerNode   Node?   @relation("TaskOwnerNode", fields: [ownerNodeId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  assigneeUserId           String?
  assigneeActorType        ActorType?
  assigneeActorId          String?
  acceptanceOwner          String?
  acceptanceOwnerActorType ActorType?
  acceptanceOwnerActorId   String?
  evidenceRequired         String[] @default([])
  version                  Int      @default(1)

  dueAt DateTime?

  assignments TaskAssignment[]
  evidences   Evidence[]
  pobRecords  PoBRecord[]
  agentRuns   AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, createdAt])
  @@index([projectId])
  @@index([ownerNodeId])
  @@index([dealId])
  @@index([workspaceId])
}

model TaskAssignment {
  id   String         @id @default(cuid())
  role AssignmentRole @default(COLLABORATOR)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([taskId, nodeId])
  @@index([nodeId])
}

// ─── EVIDENCE ───────────────────────────────────────────────────────────────

model Evidence {
  id          String       @id @default(cuid())
  workspaceId String?
  type        EvidenceType @default(OTHER)
  title       String?
  summary     String?
  url         String?
  onchainTx   String?

  fileId         String?
  hash           String?
  version        Int                  @default(1)
  versionLock    Int                  @default(1)
  reviewStatus   EvidenceReviewStatus @default(DRAFT)
  reviewedAt     DateTime?
  reviewerId     String?
  slaDeadlineAt  DateTime?

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([reviewStatus, slaDeadlineAt])
  @@index([taskId])
  @@index([projectId])
  @@index([nodeId])
  @@index([dealId])
  @@index([workspaceId])
}

// ─── POB ────────────────────────────────────────────────────────────────────

model PoBRecord {
  id           String @id @default(cuid())
  workspaceId  String?
  businessType String

  baseValue    Float @default(0)
  weight       Float @default(1)
  qualityMult  Float @default(1)
  timeMult     Float @default(1)
  riskDiscount Float @default(1)
  score        Float @default(0)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  nodeId String?
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  status ApplicationStatus @default(PENDING)

  pobEventStatus     PoBEventStatus @default(CREATED)
  leadNodeId         String?
  supportingNodeIds  String[]       @default([])
  beneficiaryEntity  String?
  resultDate         DateTime?
  loopType           String?
  slaDeadlineAt      DateTime?
  frozenAt           DateTime?
  frozenReason       String?
  version            Int            @default(1)

  notes String?

  attributions  Attribution[]
  confirmations Confirmation[]
  disputes      Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([pobEventStatus, createdAt])
  @@index([taskId])
  @@index([projectId])
  @@index([nodeId])
  @@index([dealId])
  @@index([workspaceId])
}

// ─── REVIEW / CONFIRMATION / ATTRIBUTION ────────────────────────────────────

model Review {
  id         String           @id @default(cuid())
  workspaceId String?
  targetType ReviewTargetType
  targetId   String
  decision   ReviewDecision
  notes      String?

  status        ReviewStatus @default(OPEN)
  actorType     ActorType    @default(USER)
  actorId       String?
  version       Int          @default(1)
  metadata      Json?
  slaDeadlineAt DateTime?
  decidedAt     DateTime?

  reviewerId String?
  reviewer   User?   @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([reviewerId])
  @@index([workspaceId])
}

model Confirmation {
  id         String                 @id @default(cuid())
  targetType ConfirmationTargetType
  targetId   String
  decision   ConfirmationDecision
  notes      String?

  partyType   ConfirmationPartyType
  partyUserId String?
  partyNodeId String?
  partyUser   User?                 @relation(fields: [partyUserId], references: [id], onDelete: SetNull)
  partyNode   Node?                 @relation(fields: [partyNodeId], references: [id], onDelete: SetNull)

  pobId String?
  pob   PoBRecord? @relation(fields: [pobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([partyType, createdAt])
  @@index([pobId])
}

model Attribution {
  id    String    @id @default(cuid())
  pobId String
  pob   PoBRecord @relation(fields: [pobId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  role         AttributionRole @default(COLLAB)
  shareBps     Int
  evidenceRefs String[]        @default([])

  createdAt DateTime @default(now())

  @@unique([pobId, nodeId])
  @@index([nodeId])
}

// ─── DISPUTE ────────────────────────────────────────────────────────────────

model Dispute {
  id          String           @id @default(cuid())
  workspaceId String?
  pobId       String?
  pob         PoBRecord?       @relation(fields: [pobId], references: [id], onDelete: Cascade)
  targetType  ReviewTargetType
  targetId    String
  reason      String
  status      DisputeStatus    @default(OPEN)
  resolution  String?

  windowEndsAt DateTime?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([targetType, targetId, status, createdAt])
  @@index([pobId])
  @@index([workspaceId])
}

// ─── AGENT ──────────────────────────────────────────────────────────────────

model Agent {
  id          String      @id @default(cuid())
  workspaceId String?
  name        String
  type        AgentType
  status      AgentStatus @default(ACTIVE)
  version     Int         @default(1)
  endpoint    String?

  freezeLevel AgentOverrideLevel?

  ownerNodeId String
  ownerNode   Node   @relation(fields: [ownerNodeId], references: [id], onDelete: Cascade)

  permissions AgentPermission[]
  runs        AgentRun[]
  logs        AgentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerNodeId, type, status])
  @@index([workspaceId])
}

model AgentPermission {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scope      String
  canWrite   Boolean  @default(false)
  auditLevel Int      @default(1)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([agentId, scope])
}

model AgentRun {
  id         String         @id @default(cuid())
  workspaceId String?
  agentId    String
  agent      Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  status     AgentRunStatus @default(SUCCESS)
  inputs     Json?
  outputs    Json?
  cost       Float?
  startedAt  DateTime       @default(now())
  finishedAt DateTime?

  @@index([agentId, startedAt])
  @@index([taskId])
}

model AgentLog {
  id              String   @id @default(cuid())
  workspaceId     String?
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ownerNodeId     String
  taskId          String?
  caseId          String?
  modelVersion    String?
  actionType      String
  inputReference  String?
  outputReference String?
  humanApprovalId String?
  exceptionFlag   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([taskId])
  @@index([workspaceId])
}

// ─── SETTLEMENT ─────────────────────────────────────────────────────────────

model SettlementCycle {
  id            String                @id @default(cuid())
  workspaceId   String?
  kind          SettlementCycleKind
  status        SettlementCycleStatus @default(DRAFT)
  startAt       DateTime
  endAt         DateTime
  pool          Float                 @default(0)
  policyVersion Int                   @default(1)
  metadata      Json?

  reconciledAt      DateTime?
  exportedAt        DateTime?
  reopenedAt        DateTime?
  reopenReason      String?
  lockedById        String?
  exportedById      String?
  lockApprovalId    String?
  reopenApprovalId  String?
  version           Int       @default(1)

  lines SettlementLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, startAt, endAt])
  @@index([status, startAt])
  @@index([workspaceId])
}

model SettlementLine {
  id      String          @id @default(cuid())
  cycleId String
  cycle   SettlementCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  scoreTotal Float @default(0)
  allocation Float @default(0)
  pobCount   Int   @default(0)

  createdAt DateTime @default(now())

  @@unique([cycleId, nodeId])
  @@index([nodeId])
}

// ─── NODE STAKING ───────────────────────────────────────────────────────────

model NodeSeat {
  id        String   @id @default(cuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  level     Int      @default(1)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  @@index([nodeId, level])
}

model StakeLedger {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  action    StakeAction
  amount    Float       @default(0)
  notes     String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([nodeId, createdAt])
}

model Penalty {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  type      PenaltyType
  amount    Float?
  reason    String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([nodeId, createdAt])
}

// ─── FILE LAYER ─────────────────────────────────────────────────────────────

model File {
  id                 String               @id @default(cuid())
  workspaceId        String?
  filename           String
  storageKey         String?
  storagePath        String?              // legacy
  mimeType           String?
  sizeBytes          Int?
  hash               String?
  checksumAlgorithm  String?
  version            Int                  @default(1)
  confidentiality    ConfidentialityLevel @default(PUBLIC)
  scanStatus         ScanStatus           @default(PENDING)
  previewStatus      PreviewStatus        @default(PENDING)
  retentionClass     String?
  uploadedVia        String?

  uploaderUserId String
  uploader       User   @relation("FileUploader", fields: [uploaderUserId], references: [id], onDelete: Cascade)

  entityType   String
  entityId     String
  parentFileId String?
  deletedAt    DateTime?

  accessLogs FileAccessLog[]

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([uploaderUserId])
  @@index([parentFileId])
  @@index([workspaceId])
}

model FileAccessLog {
  id          String   @id @default(cuid())
  workspaceId String?
  fileId      String
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId      String
  action      String
  ipAddress   String?
  deviceInfo  String?

  createdAt DateTime @default(now())

  @@index([fileId, createdAt])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

// ─── NOTIFICATION ───────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  workspaceId String?
  type        NotificationType @default(GENERAL)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  entityType  String?
  entityId    String?
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt, createdAt])
  @@index([workspaceId])
}

// ─── RISK ───────────────────────────────────────────────────────────────────

model RiskFlag {
  id          String    @id @default(cuid())
  workspaceId String?
  entityType  String
  entityId    String
  severity    String
  reason      String
  raisedById  String?
  resolvedAt  DateTime?
  resolution  String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([severity, createdAt])
  @@index([resolvedAt])
  @@index([workspaceId])
}

// ─── Match (Phase 2 Matching Engine) ──────────────────────────

enum MatchStatus {
  GENERATED
  INTEREST_EXPRESSED
  DECLINED
  CONVERTED_TO_DEAL
  EXPIRED
}

model Match {
  id              String      @id @default(cuid())
  projectId       String
  capitalProfileId String
  capitalNodeId   String

  score           Float       @default(0)
  sectorScore     Float       @default(0)
  stageScore      Float       @default(0)
  ticketScore     Float       @default(0)
  jurisdictionScore Float     @default(0)

  status          MatchStatus @default(GENERATED)
  interestAt      DateTime?
  declinedAt      DateTime?
  convertedDealId String?
  expiresAt       DateTime?

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  capitalProfile  CapitalProfile @relation(fields: [capitalProfileId], references: [id], onDelete: Cascade)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([projectId, capitalProfileId])
  @@index([capitalNodeId])
  @@index([status])
  @@index([score(sort: Desc)])
}
